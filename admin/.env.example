APP_NAME="Devcase"
API_BASE_URL="http://localhost:8080/api/v1"

PORT=3000

# Remote CMS images (NuxtImg uses alias `/cms/*` → this base URL)
# NUXT_IMAGES_DOMAIN is optional if derivable from NUXT_PUBLIC_IMAGES_URL
NUXT_IMAGES_DOMAIN="localhost:8080"
NUXT_PUBLIC_IMAGES_URL="http://localhost:8080/api/v1/static/images"
