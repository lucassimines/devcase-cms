{
  "name": "server",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "prisma generate && tsx watch src/server.ts",
    "migrate:projects": "tsx scripts/migrate-project-localization.ts",
    "build": "prisma generate && tsc && tsc-alias",
    "release": "prisma migrate deploy",
    "build:prod": "npm run build && npm run release",
    "clean": "rm -rf ./dist && tsc -b --clean",
    "watch": "npx tsc -b -w",
    "start": "node dist/src/server.js",
    "build:start": "npm run build && npm run start",
    "test": "vitest run"
  },
  "imports": {
    "@src/*": "./dist/src/*.js"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "bcryptjs": "^3.0.3",
    "cookie": "^1.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "lru-cache": "^11.5.1",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.1",
    "nodemailer-express-handlebars": "^7.0.0",
    "pg": "^8.18.0",
    "reflect-metadata": "^0.2.2",
    "sharp": "^0.35.2",
    "sitemap": "^9.0.1",
    "tsconfig-paths": "^4.2.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/formidable": "^3.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.2.3",
    "@types/nodemailer": "^7.0.9",
    "@types/nodemailer-express-handlebars": "^4.0.6",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.3",
    "nodemon": "^3.1.11",
    "prisma": "^7.3.0",
    "slugify": "^1.6.6",
    "supertest": "^7.1.4",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "vitest": "^4.1.5"
  }
}
