generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Page {
  id        String  @id @default(uuid())
  name      Json
  code      String  @unique
  slug      String  @unique
  order     Int     @default(0)
  published Boolean @default(false)
  content   Json?
  blocks    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  name     String
  password String

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([email])
}

model File {
  id        String @id @default(uuid())
  filename  String @unique
  extension String
  mime      String
  size      Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([filename])
}

model Project {
  id          String  @id @default(uuid())
  name        Json
  order       Int     @default(0)
  published   Boolean @default(false)
  url         Json?
  description Json?
  background  Json?
  image       Json?
  slug        String
  blocks      Json?

  // categories  Category[]

  technologies Technology[]

  solutions Solution[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

