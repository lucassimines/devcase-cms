generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Locale {
  EN_US @map("en-US")
  PT_BR @map("pt-BR")
}

model Page {
  id        String  @id @default(uuid())
  name      String
  code      String  @unique
  slug      String  @unique
  order     Int     @default(0)
  published Boolean @default(false)
  content   Json?
  blocks    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  name     String
  password String

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([email])
}

model File {
  id        String @id @default(uuid())
  filename  String @unique
  extension String
  mime      String
  size      Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([filename])
}

model Project {
  id          String  @id @default(uuid())
  name        String
  order       Int     @default(0)
  published   Boolean @default(false)
  url         String?
  description String?
  background  String?
  image       String?
  slug        String
  blocks      Json?

  technologies Technology[]

  solutions Solution[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

