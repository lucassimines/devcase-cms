model Technology {
  id   String  @id @default(uuid())
  name String
  icon String?
  url  String?
  slug String  @unique

  projects Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Solution {
  id    String @id @default(uuid())
  name  String
  order Int    @default(0)

  projects Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id    String       @id @default(uuid())
  type  CategoryType
  order Int          @default(0)
  slug  String       @unique

  parentId String?
  parent   Category?  @relation("ChildToParent", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("ChildToParent")

  translations CategoryTranslation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CategoryTranslation {
  id          String  @id @default(uuid())
  categoryId  String
  locale      Locale
  name        String
  description String?

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
  @@index([locale, name])
}

enum CategoryType {
  POST
}
