model Technology {
  id   String  @id @default(uuid())
  name String
  icon String?
  url  String?
  slug String  @unique

  projects Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Solution {
  id    String @id @default(uuid())
  name  Json
  order Int    @default(0)

  projects Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Setting {
  key   String @id
  value Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

