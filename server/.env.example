NODE_ENV="development"

APP_NAME="Devcase"
API_BASE_PATH="/api/v1"

FRONTEND_URL=

PORT=8080

SESSION_SECRET_KEY=
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=

FILESYSTEM_STORAGE_PATH='./public/images'

MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_FROM=
MAIL_USERNAME=
MAIL_PASSWORD=

DATABASE_URL="postgresql://postgres:root@localhost:5432/postgres"

# Production database — used by make db-import-prod
PROD_DATABASE_URL=

# Blog post generator (make generate-post + admin "Generate Post" button)
# Local: Cursor CLI when installed. Railway/server: Cursor Cloud Agents API (no CLI in Docker).
CURSOR_API_KEY=
POST_GENERATOR_PROVIDER="cursor"
POST_GENERATOR_CURSOR_MODEL="composer-2.5"
POST_GENERATOR_CURSOR_OUTPUT_FORMAT=text
POST_GENERATOR_TIMEOUT_MS=900000
POST_GENERATOR_WORKSPACE=
# Force transport: USE_API for Railway, USE_CLI for local make generate-post
# POST_GENERATOR_USE_API=true
# POST_GENERATOR_USE_CLI=true

# Optional — only if you use --provider openai with the CLI script
OPENAI_API_KEY=
POST_GENERATOR_MODEL="gpt-4o-mini"
POST_GENERATOR_API_URL="https://api.openai.com/v1/chat/completions"

# On-demand ISR — same value as on the Vercel frontend project
PRERENDER_REVALIDATE_TOKEN=

# Public web API cache (admin routes are never cached)
WEB_CACHE_ENABLED=true
WEB_CACHE_MAX_ENTRIES=500
WEB_CACHE_TTL_MS=300000
WEB_CACHE_MAX_AGE=60
WEB_CACHE_S_MAXAGE=300
WEB_CACHE_STALE_WHILE_REVALIDATE=600
